{
  "name": "test-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pages:dev": "wrangler pages dev dist --d1=DB --compatibility-date=2026-04-01",
    "d1:migrate:local": "wrangler d1 migrations apply test-tracker --local",
    "d1:migrate:prod": "wrangler d1 migrations apply test-tracker --remote",
    "d1:seed:local": "wrangler d1 execute test-tracker --local --file=./migrations/0002_seed.sql",
    "d1:seed:prod": "wrangler d1 execute test-tracker --remote --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  }
}
